    "@nestjs/bullmq": "^10.0.1",
    "@nestjs/typeorm": "^10.0.1",
    "@nestjs/schedule": "^4.0.0",
    "bullmq": "^5.1.0",
    "ioredis": "^5.3.2",
    "typeorm": "^0.3.19",
    "pg": "^8.11.3",
    "minio": "^7.1.3",
    "dockerode": "^4.0.0",
    "hjson": "^3.2.2",
