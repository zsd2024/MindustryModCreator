{
  "name": "mindustry-mod-creator",
  "version": "1.0.0",
  "description": "Mindustry-Scratch 在线图形化 Mod 编辑器",
  "private": true,
  "workspaces": [
    "packages/backend"
  ],
  "scripts": {
    "dev": "bun run --filter backend dev",
    "build": "bun run --filter backend build",
    "lint": "bun run --filter backend lint",
    "test": "bun run --filter backend test",
    "clean": "bun run --filter backend clean",
    "turbowarp:install": "cd packages/turbowarp && npm install",
    "turbowarp:build": "cd packages/turbowarp && npm run build",
    "turbowarp:dev": "cd packages/turbowarp && npm start"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "prettier": "^3.1.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.0.0"
  }
}